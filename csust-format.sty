% csust-format.sty
% 长沙理工大学硕士学位论文格式覆盖文件
% 基于 THUThesis 模板，覆盖格式以适配长沙理工大学论文规范
% 从摘要部分开始适配

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{csust-format}[2024/04/01 CSUST Thesis Format Override]

% ============================================================
% 1. 页面设置
%    长沙理工大学：上2.5cm，下2.5cm，左3cm，右2.5cm
% ============================================================
\geometry{
  top    = 2.5cm,
  bottom = 2.5cm,
  left   = 3cm,
  right  = 2.5cm,
  headheight = 14bp,
  headsep    = 10bp,
  footskip   = 1.2cm,
}

% ============================================================
% 2. 行距设置：1.5倍行距
% ============================================================
\renewcommand{\baselinestretch}{1.5}

% ============================================================
% 3. 页眉页脚设置
%    - 摘要、目录页（frontmatter）：无页眉，罗马数字页码居中底部
%    - 正文（mainmatter）：
%      奇数页页眉：章标题（如"第 1 章 绪论"），居中，宋体五号
%      偶数页页眉："硕士学位论文"，居中，宋体五号
%      页眉下有横线
%      页码为阿拉伯数字居中底部
% ============================================================

% 前置部分样式：无页眉，只有页码
\fancypagestyle{frontmatterstyle}{%
  \fancyhf{}%
  \renewcommand\headrulewidth{0pt}%
  \fancyfoot[C]{\wuhao\thepage}%
}

% 正文页面样式（含页眉）
\fancypagestyle{mainmatterstyle}{%
  \fancyhf{}%
  \renewcommand\headrulewidth{0.75bp}%
  \fancyhead[C]{%
    \wuhao
    \ifodd\value{page}%
      \leftmark
    \else
      硕士学位论文%
    \fi
  }%
  \fancyfoot[C]{\wuhao\thepage}%
  \let\@mkboth\markboth
  \def\chaptermark##1{%
    \markboth{%
      \CTEXifname{%
        \CTEXthechapter
        \quad
      }{}%
      ##1%
    }{}%
  }%
  \let\sectionmark\@gobble
}

% 章首页样式：与正文样式相同（有页眉有横线）
\fancypagestyle{chapter}{%
  \fancyhf{}%
  \renewcommand\headrulewidth{0.75bp}%
  \fancyhead[C]{%
    \wuhao
    \ifodd\value{page}%
      \leftmark
    \else
      硕士学位论文%
    \fi
  }%
  \fancyfoot[C]{\wuhao\thepage}%
}

% 前置部分的章首页样式（无页眉）
\fancypagestyle{front-chapter}{%
  \fancyhf{}%
  \renewcommand\headrulewidth{0pt}%
  \fancyfoot[C]{\wuhao\thepage}%
}

% ============================================================
% 4. 章标题格式
%    "第 X 章 标题"：黑体，三号(16pt)，居中，加粗
% ============================================================
\ctexset{%
  chapter = {
    format      = \centering\sffamily\bfseries\fontsize{16bp}{26bp}\selectfont,
    nameformat  = {},
    titleformat = {},
    name        = {第,章},
    aftername   = \quad,
    number      = \thechapter,
    beforeskip  = 24bp,
    afterskip   = 18bp,
    fixskip     = true,
    afterindent = true,
    lofskip     = 0pt,
    lotskip     = 0pt,
  },
  % 节标题：黑体，四号(14pt)，左对齐，加粗
  section = {
    format      = \sffamily\bfseries\fontsize{14bp}{22bp}\selectfont,
    aftername   = \quad,
    afterindent = true,
    beforeskip  = 18bp,
    afterskip   = 6bp,
  },
  % 小节标题：黑体，小四号(12pt)，左对齐，加粗
  subsection = {
    format      = \sffamily\bfseries\fontsize{12bp}{20bp}\selectfont,
    aftername   = \quad,
    afterindent = true,
    beforeskip  = 12bp,
    afterskip   = 6bp,
  },
  subsubsection = {
    format      = \sffamily\bfseries\fontsize{12bp}{20bp}\selectfont,
    aftername   = \quad,
    afterindent = true,
    beforeskip  = 12bp,
    afterskip   = 6bp,
  },
  paragraph/afterindent = true,
  subparagraph/afterindent = true,
}

% ============================================================
% 5. 摘要标题格式
%    中文："摘  要"，黑体三号，居中
%    英文："ABSTRACT"，Times New Roman 三号，居中，加粗
% ============================================================
\renewcommand{\thu@abstract@name}{摘\quad 要}
\renewcommand{\thu@abstract@name@en}{ABSTRACT}

% ============================================================
% 6. 目录格式
%    标题"目录"：黑体，三号，居中
%    章标题加粗，节标题有缩进层次
%    点线连接，页码右对齐
% ============================================================
\RequirePackage{titletoc}
\newcommand\csust@set@toc@format{%
  \contentsmargin{\z@}%
  \titlecontents{chapter}
    [\z@]{\sffamily\bfseries}
    {\contentspush{\thecontentslabel\quad}}{}
    {\rmfamily\normalfont\titlerule*[4bp]{.}\thecontentspage}%
  \titlecontents{section}
    [1.5em]{}
    {\contentspush{\thecontentslabel\quad}}{}
    {\titlerule*[4bp]{.}\thecontentspage}%
  \titlecontents{subsection}
    [3.5em]{}
    {\contentspush{\thecontentslabel\quad}}{}
    {\titlerule*[4bp]{.}\thecontentspage}%
}

% ============================================================
% 7. 图表标题格式
%    图标题在图下方，表标题在表上方，宋体五号
% ============================================================
\captionsetup{
  font           = {small},
  labelsep       = quad,
  skip           = 6bp,
  figureposition = bottom,
  tableposition  = top,
}

% ============================================================
% 8. frontmatter / mainmatter / backmatter 页面样式切换
% ============================================================
\let\orig@frontmatter\frontmatter
\renewcommand\frontmatter{%
  \orig@frontmatter
  \pagestyle{frontmatterstyle}%
  \ctexset{chapter/pagestyle = front-chapter}%
  \pagenumbering{Roman}%
}

\let\orig@mainmatter\mainmatter
\renewcommand\mainmatter{%
  \orig@mainmatter
  \pagestyle{mainmatterstyle}%
  \ctexset{chapter/pagestyle = chapter}%
  \pagenumbering{arabic}%
}

\let\orig@backmatter\backmatter
\renewcommand\backmatter{%
  \orig@backmatter
  \pagestyle{mainmatterstyle}%
  \ctexset{chapter/pagestyle = chapter}%
}

\endinput
